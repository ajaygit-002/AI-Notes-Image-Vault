      "name": "Vault - Get Item",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost:5000/api/vault/VAULT_ITEM_ID", "host": ["localhost"], "port": "5000", "path": ["api","vault","VAULT_ITEM_ID"] }
      }
