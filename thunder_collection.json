{
  "type": "collection",
  "name": "AI Notes & Image Vault - Localhost",
  "version": "1.0",
  "item": [
    {
      "name": "Root",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost:5000/", "host": ["localhost"], "port": "5000", "path": [""] }
      }
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost:5000/health", "host": ["localhost"], "port": "5000", "path": ["health"] }
      }
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret123\"\n}" },
        "url": { "raw": "http://localhost:5000/api/auth/register", "host": ["localhost"], "port": "5000", "path": ["api","auth","register"] }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret123\"\n}" },
        "url": { "raw": "http://localhost:5000/api/auth/login", "host": ["localhost"], "port": "5000", "path": ["api","auth","login"] }
      }
    },
    {
      "name": "Auth - Demo Create User",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost:5000/api/auth/demo-create-user", "host": ["localhost"], "port": "5000", "path": ["api","auth","demo-create-user"] }
      }
    },
    {
      "name": "Auth - Forgot (manual reset)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@example.com\",\n  \"newPassword\": \"newpass123\",\n  \"confirmPassword\": \"newpass123\"\n}" },
        "url": { "raw": "http://localhost:5000/api/auth/forgot-password", "host": ["localhost"], "port": "5000", "path": ["api","auth","forgot-password"] }
      }
    },
    {
      "name": "Auth - Verify Reset Token",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"token\": \"PUT_TOKEN_HERE\"\n}" },
        "url": { "raw": "http://localhost:5000/api/auth/verify-reset-token", "host": ["localhost"], "port": "5000", "path": ["api","auth","verify-reset-token"] }
      }
    },
    {
      "name": "Auth - Profile (requires token)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer <TOKEN>" }],
        "url": { "raw": "http://localhost:5000/api/auth/profile", "host": ["localhost"], "port": "5000", "path": ["api","auth","profile"] }
      }
    },
    {
      "name": "Auth - Change Password (auth)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer <TOKEN>" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"secret123\",\n  \"newPassword\": \"newpass123\",\n  \"confirmPassword\": \"newpass123\"\n}" },
        "url": { "raw": "http://localhost:5000/api/auth/change-password", "host": ["localhost"], "port": "5000", "path": ["api","auth","change-password"] }
      }
    },
    {
      "name": "Notes - Create (auth)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer <TOKEN>" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Test note\",\n  \"content\": \"Hello world\"\n}" },
        "url": { "raw": "http://localhost:5000/api/notes", "host": ["localhost"], "port": "5000", "path": ["api","notes"] }
      }
    },
    {
      "name": "Notes - List (auth)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer <TOKEN>" }],
        "url": { "raw": "http://localhost:5000/api/notes", "host": ["localhost"], "port": "5000", "path": ["api","notes"] }
      }
    },
    {
      "name": "Notes - Stats (auth)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer <TOKEN>" }],
        "url": { "raw": "http://localhost:5000/api/notes/stats", "host": ["localhost"], "port": "5000", "path": ["api","notes","stats"] }
      }
    },
