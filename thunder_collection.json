      "name": "Notes - Update (auth)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer <TOKEN>" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated\",\n  \"content\": \"New content\"\n}" },
        "url": { "raw": "http://localhost:5000/api/notes/NOTE_ID", "host": ["localhost"], "port": "5000", "path": ["api","notes","NOTE_ID"] }
      }
    },
    {
      "name": "Notes - Delete (auth)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer <TOKEN>" }],
        "url": { "raw": "http://localhost:5000/api/notes/NOTE_ID", "host": ["localhost"], "port": "5000", "path": ["api","notes","NOTE_ID"] }
      }
    },
    {
      "name": "Suggest Corrections",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"text\": \"Ths is a test sentence.\"\n}" },
        "url": { "raw": "http://localhost:5000/api/notes/suggest-corrections", "host": ["localhost"], "port": "5000", "path": ["api","notes","suggest-corrections"] }
      }
    },
    {
      "name": "Vault - Upload (multipart)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "image", "type": "file", "src": "/path/to/photo.jpg" },
            { "key": "password", "type": "text", "value": "1234" }
          ]
        },
        "url": { "raw": "http://localhost:5000/api/vault/upload", "host": ["localhost"], "port": "5000", "path": ["api","vault","upload"] }
      }
    },
    {
      "name": "Vault - List",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "http://localhost:5000/api/vault", "host": ["localhost"], "port": "5000", "path": ["api","vault"] }
      }
    },
